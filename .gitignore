dist/
build/
ui-dist/
*.tgz
.turbo/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage
coverage/
.nyc_output/

# Environment
.env
.env.*
!.env.example

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Claude Code session state (worktrees, local settings)
.claude/

# Stray local build / runtime artifacts (not the published `dist/`)
dist-runtime/

