# Reference projects — third-party code studied as prior art, NOT dependencies.
# Kept locally for offline reading; never committed.
references/

# Local strategy / private notes — never committed to the OSS repo.
.strategy/

# Per-package copies of root docs, refreshed by `npm run prepack` before
# publish. Single source of truth lives at the repo root.
packages/agentfw/LICENSE
packages/agentfw/README.md
packages/agentfw/PRIVACY.md

